{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/skills/octo/scripts/run_python.sh\" --version 2>/dev/null || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -NoLogo -Command 'Write-Host \"PowerShell $($PSVersionTable.PSVersion)\"' 2>/dev/null || true",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
